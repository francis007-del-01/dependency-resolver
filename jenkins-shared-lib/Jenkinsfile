pipeline {
    agent any

    triggers {
        cron('H/10 * * * *')
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Build') {
            steps {
                sh 'cd /var/jenkins_home/project && mvn clean package -pl resolver-core -am -DskipTests'
            }
        }
        stage('Run') {
            steps {
                withCredentials([string(credentialsId: 'github-api-token', variable: 'GITHUB_TOKEN')]) {
                    sh 'java -jar /var/jenkins_home/project/resolver-core/target/resolver-core-1.0.0-SNAPSHOT.jar'
                }
            }
        }
    }

    post {
        failure {
            echo "Dependency resolver cron job failed. Check logs for details."
        }
        success {
            echo "Dependency resolver completed successfully."
        }
    }
}
