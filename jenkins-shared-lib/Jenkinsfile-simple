pipeline {
    agent any

    parameters {
        string(name: 'OWNER', description: 'GitHub repo owner (org)', defaultValue: '')
        string(name: 'REPO',  description: 'GitHub repo name',       defaultValue: '')
        string(name: 'BRANCH', description: 'Target branch to update', defaultValue: '')
        string(name: 'POM_PATH', description: 'Path to pom.xml within the repo', defaultValue: 'pom.xml')
    }

    options {
        timeout(time: 10, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Validate Inputs') {
            steps {
                script {
                    if (!params.OWNER?.trim() || !params.REPO?.trim() || !params.BRANCH?.trim()) {
                        error "OWNER, REPO, and BRANCH parameters are all required."
                    }
                    echo "Resolving dependencies for ${params.OWNER}/${params.REPO}@${params.BRANCH}"
                }
            }
        }

        stage('Run Resolver') {
            steps {
                withCredentials([
                    string(credentialsId: 'github-api-token',   variable: 'GITHUB_TOKEN'),
                    string(credentialsId: 'artifactory-token',  variable: 'ARTIFACTORY_TOKEN'),
                ]) {
                    sh '''
                        java -jar /opt/resolver-core.jar \
                            --owner="${OWNER}" \
                            --repo="${REPO}" \
                            --branch="${BRANCH}" \
                            --pomPath="${POM_PATH}"
                    '''
                }
            }
        }
    }

    post {
        failure { echo "Dependency resolver failed for ${params.OWNER}/${params.REPO}@${params.BRANCH}" }
        success { echo "Dependency resolver completed for ${params.OWNER}/${params.REPO}@${params.BRANCH}" }
    }
}
