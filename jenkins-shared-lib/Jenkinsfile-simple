pipeline {
    agent any

    parameters {
        text(name: 'REPOS', defaultValue: '''
# Format: <github-url>  trigger=<branch>  target=<branch1,branch2>
# trigger = read version from this branch (source of truth)
# target  = update dependencies on these branches (create PRs)
# Both are optional per repo. Examples:
#
# https://github.com/myorg/core-lib       trigger=master
# https://github.com/myorg/service-a      target=master,develop
# https://github.com/myorg/service-b      trigger=master  target=master,develop
''', description: 'Repos with trigger/target branches')
    }

    environment {
        BRANCH_PREFIX = 'deps'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Resolve Dependencies') {
            steps {
                withCredentials([string(credentialsId: 'github-api-token', variable: 'GITHUB_TOKEN')]) {
                    script {
                        // === Parse input ===
                        def repoConfigs = parseInput(params.REPOS)
                        echo "Parsed ${repoConfigs.size()} repos"

                        // === Phase 1: Clone trigger repos, build version map ===
                        echo "=== Phase 1: Building version map from trigger branches ==="
                        def latestVersions = buildVersionMap(repoConfigs)
                        echo "Version map: ${latestVersions.size()} artifacts"

                        // === Phase 2: For each target repo+branch, update deps and create PRs ===
                        echo "=== Phase 2: Updating target branches ==="
                        def created = 0, skipped = 0, failed = 0

                        for (config in repoConfigs) {
                            if (!config.targetBranches) continue

                            for (branch in config.targetBranches) {
                                try {
                                    def result = updateAndPr(config, branch, latestVersions)
                                    if (result == 1) created++
                                    else skipped++
                                } catch (Exception e) {
                                    echo "Failed ${config.owner}/${config.name} (${branch}): ${e.message}"
                                    failed++
                                }
                            }
                        }

                        echo "=== Done. PRs created: ${created}, Skipped: ${skipped}, Failed: ${failed} ==="
                    }
                }
            }
        }
    }

    post {
        always { deleteDir() }
    }
}

// --- Parse input lines into repo configs ---
def parseInput(String input) {
    def configs = []
    for (line in input.trim().split('\n')) {
        line = line.trim()
        if (!line || line.startsWith('#')) continue

        def match = (line =~ /github\.com\/([^\/]+)\/([^\/\.\s]+)/)
        if (!match) continue

        def owner = match[0][1]
        def name = match[0][2]

        def triggerMatch = (line =~ /trigger=(\S+)/)
        def triggerBranch = triggerMatch ? triggerMatch[0][1] : null

        def targetMatch = (line =~ /target=(\S+)/)
        def targetBranches = targetMatch ? targetMatch[0][1].split(',').collect { it.trim() } : null

        configs.add([
            owner: owner,
            name: name,
            triggerBranch: triggerBranch,
            targetBranches: targetBranches
        ])

        echo "  ${owner}/${name}  trigger=${triggerBranch ?: 'none'}  target=${targetBranches ?: 'none'}"
    }
    return configs
}

// --- Clone trigger repos and read their versions ---
def buildVersionMap(List repoConfigs) {
    def latestVersions = [:]

    for (config in repoConfigs) {
        if (!config.triggerBranch) continue

        try {
            def workDir = "${WORKSPACE}/trigger-${config.name}"
            sh "rm -rf ${workDir}"
            sh "git clone --branch ${config.triggerBranch} --depth 1 https://x-access-token:${GITHUB_TOKEN}@github.com/${config.owner}/${config.name}.git ${workDir}"

            def pomFile = "${workDir}/pom.xml"
            def coords = readPomCoordinates(pomFile)

            if (coords.groupId && coords.artifactId && coords.version) {
                latestVersions["${coords.groupId}:${coords.artifactId}"] = coords.version
                echo "  ${coords.groupId}:${coords.artifactId} = ${coords.version} (from ${config.owner}/${config.name}:${config.triggerBranch})"
            }

            sh "rm -rf ${workDir}"
        } catch (Exception e) {
            echo "Could not read version from ${config.owner}/${config.name}: ${e.message}"
        }
    }

    return latestVersions
}

// --- Read groupId, artifactId, version from a pom.xml ---
def readPomCoordinates(String pomFile) {
    def result = sh(
        script: """python3 -c "
import xml.etree.ElementTree as ET
tree = ET.parse('${pomFile}')
root = tree.getroot()
ns = {'m': 'http://maven.apache.org/POM/4.0.0'}

gid = root.find('m:groupId', ns)
if gid is None:
    gid = root.find('m:parent/m:groupId', ns)

aid = root.find('m:artifactId', ns)

ver = root.find('m:version', ns)
if ver is None:
    ver = root.find('m:parent/m:version', ns)

print(gid.text.strip() if gid is not None else '')
print(aid.text.strip() if aid is not None else '')
print(ver.text.strip() if ver is not None else '')
" """,
        returnStdout: true
    ).trim().split('\n')

    return [groupId: result[0], artifactId: result[1], version: result[2]]
}

// --- Clone a target branch, update deps, create PR ---
def updateAndPr(Map config, String branch, Map latestVersions) {
    def workDir = "${WORKSPACE}/target-${config.name}-${branch}"
    sh "rm -rf ${workDir}"
    sh "git clone --branch ${branch} --depth 1 https://x-access-token:${GITHUB_TOKEN}@github.com/${config.owner}/${config.name}.git ${workDir}"

    // Find all pom.xml files
    def pomFiles = sh(
        script: "find ${workDir} -name 'pom.xml' -not -path '*/target/*'",
        returnStdout: true
    ).trim().split('\n').findAll { it }

    // Update each dependency that has a newer version in the map
    for (pomFile in pomFiles) {
        for (entry in latestVersions) {
            def parts = entry.key.split(':')
            def depGroupId = parts[0]
            def depArtifactId = parts[1]
            def latestVersion = entry.value

            sh """
                python3 -c "
import re
with open('${pomFile}', 'r') as f:
    content = f.read()

updated = False

# Direct version in dependency block
pattern = r'(<dependency>\\s*(?:(?!</dependency>).)*<groupId>\\s*${depGroupId}\\s*</groupId>\\s*(?:(?!</dependency>).)*<artifactId>\\s*${depArtifactId}\\s*</artifactId>\\s*(?:(?!</dependency>).)*<version>\\s*)([^<]+)(\\s*</version>)'
match = re.search(pattern, content, flags=re.DOTALL)
if match and match.group(2).strip() != '${latestVersion}':
    content = re.sub(pattern, r'\\g<1>${latestVersion}\\3', content, flags=re.DOTALL)
    updated = True

# Property-based version
prop_pattern = r'(<${depArtifactId}\\.version>)([^<]+)(</.*version>)'
prop_match = re.search(prop_pattern, content)
if prop_match and prop_match.group(2).strip() != '${latestVersion}':
    content = re.sub(prop_pattern, r'\\g<1>${latestVersion}\\3', content)
    updated = True

if updated:
    with open('${pomFile}', 'w') as f:
        f.write(content)
    print('UPDATED')
else:
    print('NO_CHANGE')
"
            """
        }
    }

    // Check if any changes were made
    def hasChanges = sh(
        script: "cd ${workDir} && git diff --quiet && echo 'clean' || echo 'dirty'",
        returnStdout: true
    ).trim()

    if (hasChanges == 'clean') {
        echo "${config.name} (${branch}): already up to date"
        sh "rm -rf ${workDir}"
        return 0
    }

    // Create branch, commit, push, PR
    def branchName = "${BRANCH_PREFIX}/${branch}/bump-deps-${System.currentTimeMillis()}"

    sh """
        cd ${workDir}
        git checkout -b ${branchName}
        git add -A
        git commit -m "chore(deps): update dependencies to latest versions"
        git push origin ${branchName}
    """

    sh """
        curl -s -X POST \
            -H "Authorization: Bearer ${GITHUB_TOKEN}" \
            -H "Accept: application/vnd.github+json" \
            https://api.github.com/repos/${config.owner}/${config.name}/pulls \
            -d '{
                "title": "chore(deps): update dependencies to latest versions",
                "body": "## Automated Dependency Update\\n\\nUpdated dependencies to latest versions.\\n\\nCreated by dependency-resolver Jenkins job.",
                "head": "${branchName}",
                "base": "${branch}"
            }'
    """

    echo "${config.name} (${branch}): PR created"
    sh "rm -rf ${workDir}"
    return 1
}
